# ==============================================================================
#  SEEN POS — Environment Variables Template (.env.example)
# ==============================================================================
#  WARNING: This file is a TEMPLATE only. NEVER put real secrets here.
#  Copy this file to `.env.local` (git-ignored) and fill in real values there.
#  Any VITE_* variable is bundled into the public client JS — it must be a
#  PUBLIC key only. Never place a service_role / admin / private key in a VITE_*
#  variable.
# ==============================================================================

# --- Google Gemini AI ---
# Required for Gemini AI API calls. Keep server-side only.
GEMINI_API_KEY="<your-gemini-api-key>"

# Public URL where the app is hosted (OAuth callbacks, self links).
APP_URL="<your-app-url>"

# --- Firebase Client (public web config — safe to expose) ---
VITE_FIREBASE_API_KEY="<firebase-web-api-key>"
VITE_FIREBASE_AUTH_DOMAIN="<project>.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="<project-id>"
VITE_FIREBASE_STORAGE_BUCKET="<project>.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="<sender-id>"
VITE_FIREBASE_APP_ID="<app-id>"

# --- Firebase Admin (server-side ONLY — never exposed to the browser) ---
# Path to a service-account JSON file OR the JSON contents, injected at runtime
# from a secret manager. Do NOT commit the actual key file to the repo.
FIREBASE_SERVICE_ACCOUNT="<path-or-json-from-secret-manager>"

# --- Supabase ---
# URL of the Supabase project.
VITE_SUPABASE_URL="<https://your-project.supabase.co>"
# PUBLIC anon key ONLY (role: "anon"). This is shipped to the browser.
# DO NOT use the service_role key here — it bypasses all RLS.
VITE_SUPABASE_ANON_KEY="<supabase-anon-public-key>"
# service_role key (role: "service_role") — server-side ONLY, never VITE_*.
SUPABASE_SERVICE_ROLE_KEY="<server-side-only-service-role-key>"
